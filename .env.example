# Trident 环境变量配置
# 复制此文件为 .env 并填入真实值
# .env 文件不会被提交到 Git（已在 .gitignore 中）

# ============================================
# 安全相关（必须配置）
# ============================================
# Flask 会话密钥，用于加密 session cookie
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
TRIDENT_SECRET_KEY=your-secret-key-here

# 管理员密码哈希（Werkzeug 格式）
# 生成方式: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your_password'))"
TRIDENT_PASSWORD_HASH=scrypt:...

# ============================================
# 告警相关（可选）
# ============================================
# Webhook 告警地址，留空则禁用
TRIDENT_WEBHOOK_URL=

# ============================================
# 网站路径（可选，覆盖 config.toml）
# ============================================
# 监控目标网站根目录
# TRIDENT_WEBSITE_PATH=/var/www/html
