# Trident v1.7.9 — 环境变量配置模板
# 复制此文件为 .env 后填入真实值
# .env 已加入 .gitignore，切勿提交到版本控制

# ============================================
# 核心安全密钥（必须修改）
# ============================================
TRIDENT_SECRET_KEY=change_this_to_a_random_32_char_string_in_production
TRIDENT_PASSWORD_HASH=your_bcrypt_hash_here

# ============================================
# Notifier 通知凭证（按需填写）
# ============================================

# --- 邮件 SMTP ---
TRIDENT_EMAIL_USERNAME=your_email@163.com
TRIDENT_EMAIL_PASSWORD=your_smtp_password_here
TRIDENT_EMAIL_FROM=your_email@163.com
TRIDENT_EMAIL_TO=recipient@qq.com

# --- 微信 Server 酱 API Key ---
# 获取地址: https://sct.ftqq.com/
TRIDENT_WECHAT_API_KEY=your_serverchan_key_here

# --- Webhook 密钥（如需要签名验证） ---
TRIDENT_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# 可选：开发调试
# ============================================
# TRIDENT_DEBUG=true
# TRIDENT_TOOL_MODE=true
